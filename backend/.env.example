# ContentForge Alchemy API - Environment Configuration

# Server Port
PORT=8080

# Database Connection (MySQL)
DATABASE_URL="mysql://root:password@localhost:3306/contentforge"

# Authentication
# IMPORTANT: Change this to a long, random string in production
JWT_SECRET="your_jwt_secret_here_make_it_long_and_random"

# AI Engine - Google Gemini
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# Email Service - Resend
# Get your key at: https://resend.com/
RESEND_API_KEY="re_your_resend_api_key"
FROM_EMAIL="ContentForge <onboarding@resend.dev>"

# Frontend URL (for email links)
FRONTEND_URL="http://localhost:3000"

# Stripe (Webhooks & Payments)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Node Environment
NODE_ENV="development"
