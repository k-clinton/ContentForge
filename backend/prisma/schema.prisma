// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String?
  avatar        String?
  apiKey        String?
  credits       Int            @default(2500)
  maxCredits    Int            @default(2500)
  plan          String         @default("Pro Member")
  
  // Settings & Preferences
  emailNotifications  Boolean @default(true)
  inAppNotifications Boolean @default(true)
  defaultLanguage    String  @default("English")
  defaultLength      String  @default("Medium")
  theme              String  @default("dark")

  notifications Notification[]
  activities    Activity[]
  synthesisJobs SynthesisJob[]
  vaultItems    VaultItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  type        String
  icon        String
  color       String
  bg          String
  isRead      Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model Activity {
  id        String   @id @default(cuid())
  task      String
  engine    String
  status    String
  tokens    String
  progress  Int
  impact    String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model SynthesisJob {
  id          String   @id @default(cuid())
  sourceText  String?  @db.Text
  url         String?
  outputText  String   @db.Text
  platform    String   // e.g., "LinkedIn", "Twitter"
  voice       String   // e.g., "Professional"
  depth       Int      @default(70)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model VaultItem {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  content     String   @db.Text
  platform    String
  image       String?  @db.Text
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}
