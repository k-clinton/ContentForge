# Server Configuration
PORT=8080

# Database Configuration
# Prisma connection string (Example for Local MySQL/MariaDB)
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME"

# JWT Authentication
JWT_SECRET="your_highly_secure_random_secret_here"

# AI Provider Configuration (Required for Phase 1)
# Get your Gemini API Key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# Email Configuration (Resend)
RESEND_API_KEY="re_123456789"
FROM_EMAIL="ContentForge <onboarding@resend.dev>"
FRONTEND_URL="http://localhost:3000"

# Optional: OpenAI Configuration
# OPENAI_API_KEY="your_openai_api_key_here"

# Coming Soon: Social Connectors
# YOUTUBE_API_KEY=""
# TIKTOK_CLIENT_ID=""
